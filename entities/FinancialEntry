{
  "name": "FinancialEntry",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "income",
        "expense"
      ],
      "description": "Receita ou despesa"
    },
    "category": {
      "type": "string",
      "description": "Categoria"
    },
    "description": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o"
    },
    "amount": {
      "type": "number",
      "description": "Valor"
    },
    "due_date": {
      "type": "string",
      "format": "date",
      "description": "Data de vencimento"
    },
    "paid_date": {
      "type": "string",
      "format": "date",
      "description": "Data de pagamento"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "paid",
        "overdue",
        "cancelled"
      ],
      "default": "pending"
    },
    "payment_method": {
      "type": "string",
      "enum": [
        "pix",
        "cash",
        "credit_card",
        "debit_card",
        "bank_transfer",
        "boleto"
      ],
      "description": "Forma de pagamento"
    },
    "service_order_id": {
      "type": "string",
      "description": "OS vinculada"
    },
    "client_id": {
      "type": "string",
      "description": "Cliente vinculado"
    },
    "client_name": {
      "type": "string",
      "description": "Nome do cliente"
    }
  },
  "required": [
    "type",
    "amount",
    "description"
  ]
}